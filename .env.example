# MongoDB (local: docker compose). Mongoose usa DATABASE_URL completa (incluye nombre de base en el path).
DATABASE_URL="mongodb://127.0.0.1:27017/dreamia"

# Opcional: si la URI no incluye nombre de base, definí MONGODB_DATABASE=dreamia
# MONGODB_DATABASE=dreamia

# Opcional
PORT=3000

# CORS: por defecto localhost:8081, :3000 y :8080. En producción, lista separada por comas (sin espacios obligatorios).
# CORS_ORIGINS=https://app.tudominio.com,https://admin.tudominio.com
# Solo si el front envía cookies o credenciales cross-origin:
# CORS_CREDENTIALS=true

# Metadatos en GET / (opcional): si no se define, se usa NODE_ENV (p. ej. development en local, production en Docker).
# APP_ENV=staging

# Cloudinary — imágenes de sueño (`dreamImages`) y POST /cloudinary/upload-signature
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# Prefijo raíz para carpetas: dreams → {prefijo}/dreams; catálogo → {prefijo}/catalog/characters|locations|objects
# CLOUDINARY_ROOT_PREFIX=dreamia
# Opcional: upload preset en la firma
# CLOUDINARY_UPLOAD_PRESET=

# Sugerencias de entidades (POST /ai/suggest-entities) — ver docs/ai-suggestions.md
# DeepSeek (por defecto: modelo deepseek-chat, base https://api.deepseek.com/v1)
AI_API_KEY=
# Compatibilidad: si solo tenés OPENAI_API_KEY, también se usa.
# OPENAI_API_KEY=
# AI_MODEL=deepseek-chat
# AI_BASE_URL=https://api.deepseek.com/v1
# Otro proveedor compatible (ej. OpenAI): AI_BASE_URL=https://api.openai.com/v1 AI_MODEL=gpt-4o-mini
