# Opcional
PORT=3000

# MongoDB — requerido para el dominio (URI completa, incluye nombre de base si aplica)
MONGODB_URI=mongodb://127.0.0.1:27017/dreamia
# Si tenías solo DATABASE_URL, usá el mismo valor en MONGODB_URI y borrá el nombre viejo.

# CORS: por defecto localhost:8081, :3000 y :8080. En producción, lista separada por comas.
# CORS_ORIGINS=https://app.tudominio.com,https://admin.tudominio.com
# CORS_CREDENTIALS=true

# Metadatos en GET / y GET /meta (ambiente mostrado en la app)
# APP_ENV=staging
# Commit en pantalla “Información del sistema” si no hay git al build (CI):
# GIT_COMMIT=abc1234

# Cloudinary — POST /cloudinary/upload
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_ROOT_PREFIX=dreamia

# IA — POST /dream-sessions/:id/ai/suggest-elements | suggest-thought — ver docs/ai-suggestions.md
AI_API_KEY=
# OPENAI_API_KEY=
# AI_MODEL=deepseek-chat
# AI_BASE_URL=https://api.deepseek.com/v1
